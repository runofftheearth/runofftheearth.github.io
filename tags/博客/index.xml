    <item>
      <title>一 通过Hugo搭建博客</title>
      <link>https://ziyue.tech/post/%E4%B8%80%20%E9%80%9A%E8%BF%87Hugo%E6%90%AD%E5%BB%BA%E5%8D%9A%E5%AE%A2.html</link>
